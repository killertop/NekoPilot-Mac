{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "identifier": "dev.nekopilot.desktop",
  "productName": "NekoPilot",
  "app": {
    "windows": [
      {
        "devtools": false,
        "maximizable": false,
        "decorations": true,
        "resizable": false,
        "title": "NekoPilot",
        "width": 320,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:;"
    }
  },
  "bundle": {
    "targets": [
      "deb",
      "rpm"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "resources/main.desktop"
      },
      "rpm": {
        "desktopTemplate": "resources/main.desktop"
      }
    },
    "externalBin": [
      "binaries/sing-box"
    ]
  }
}
