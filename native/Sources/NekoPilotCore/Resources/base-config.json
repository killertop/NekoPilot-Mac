{
  "log": {
    "disabled": false,
    "level": "warn",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "local",
        "type": "local"
      },
      {
        "tag": "system",
        "type": "udp",
        "server": "223.5.5.5",
        "server_port": 53
      },
      {
        "tag": "dns_proxy",
        "type": "tcp",
        "server": "1.0.0.1",
        "server_port": 53,
        "detour": "ExitGateway"
      }
    ],
    "rules": [
      {
        "preferred_by": ["local"],
        "action": "route",
        "server": "local"
      },
      {
        "domain_suffix": ["local", "lan", "localdomain", "localhost"],
        "action": "route",
        "server": "local"
      },
      {
        "action": "evaluate",
        "server": "dns_proxy"
      },
      {
        "match_response": true,
        "rule_set": ["geoip-cn"],
        "action": "route",
        "server": "system"
      },
      {
        "rule_set": ["geosite-cn"],
        "action": "route",
        "server": "system"
      }
    ],
    "final": "dns_proxy",
    "strategy": "prefer_ipv4",
    "cache_capacity": 2048,
    "timeout": "5s"
  },
  "inbounds": [
    {
      "tag": "mixed",
      "type": "mixed",
      "listen": "127.0.0.1",
      "listen_port": 6789
    }
  ],
  "route": {
    "rules": [
      {
        "action": "sniff"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          { "protocol": "dns" },
          { "port": 53 }
        ],
        "action": "hijack-dns"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "domain_suffix": ["local", "lan", "localdomain", "localhost"],
        "outbound": "direct"
      },
      {
        "domain": ["direct-tag.nekopilot.invalid"],
        "domain_suffix": [],
        "ip_cidr": [],
        "outbound": "direct"
      },
      {
        "domain": ["proxy-tag.nekopilot.invalid"],
        "domain_suffix": [],
        "ip_cidr": [],
        "outbound": "ExitGateway"
      },
      {
        "rule_set": ["geosite-cn", "geoip-cn"],
        "outbound": "direct"
      }
    ],
    "final": "ExitGateway",
    "default_domain_resolver": "system",
    "auto_detect_interface": true,
    "rule_set": [
      {
        "tag": "geoip-cn",
        "type": "local",
        "format": "binary"
      },
      {
        "tag": "geosite-cn",
        "type": "local",
        "format": "binary"
      }
    ]
  },
  "experimental": {
    "cache_file": {}
  },
  "outbounds": [
    {
      "tag": "direct",
      "type": "direct",
      "domain_resolver": "system"
    },
    {
      "tag": "ExitGateway",
      "type": "selector",
      "outbounds": []
    }
  ]
}
